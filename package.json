{
  "name": "bryantotty-site",
  "version": "1.0.0",
  "description": "Personal website for Bryan Totty — bryantotty.com. Static HTML + Tailwind CDN + a small Etsy merch sync.",
  "private": true,
  "type": "module",
  "scripts": {
    "merch:sync": "node scripts/sync-etsy-merch.mjs",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.css --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19"
  }
}
